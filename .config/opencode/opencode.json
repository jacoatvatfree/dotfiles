{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "mcp": {
    "mongodb": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mongodb-mcp-server",
        "--connectionString",
        "mongodb://127.0.0.1:27017",
        "--readonly"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--isolated", "--browser", "firefox"],
      "enabled": true
    }
  }
}
